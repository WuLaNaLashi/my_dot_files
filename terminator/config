[global_config]
  inactive_color_offset = 0.7999999999999999
  suppress_multiple_term_dialog = True
  always_split_with_profile = True
[keybindings]
[profiles]
  [[default]]
    allow_bold = False
    background_color = "#ffffff"
    background_darkness = 0.96
    background_image = /home/hanxiao/Pictures/wallhaven-j8oqjq.png
    font = JetBrains Mono NL Light 14
    foreground_color = "#000000"
    scrollbar_position = hidden
    scrollback_lines = 9000
    use_theme_colors = True
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
      size = 1450, 600
    [[[child1]]]
      type = Terminal
      parent = window0
      profile = default
[plugins]
